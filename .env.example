# Web
# Leave blank for Docker/local hostname auto-detection, or set explicitly if needed.
NEXT_PUBLIC_API_URL=
INTERNAL_API_URL=http://api:8000

# API
AUTH_MODE=local_open
DATABASE_URL=postgresql+asyncpg://dreamaxis:dreamaxis@postgres:5432/dreamaxis
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-me-dreamaxis-development-secret
APP_ENCRYPTION_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://host.docker.internal:3000,http://web:3000
RUNTIME_SHARED_TOKEN=dreamaxis-runtime-token
WORKSPACE_ROOT_BASE=/workspace
ENABLE_BROWSER_RUNTIME=true

# Optional development fallback connection
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Knowledge
KNOWLEDGE_STORAGE_PATH=/data/knowledge
KNOWLEDGE_TOP_K=4
KNOWLEDGE_CHUNK_SIZE=1200
KNOWLEDGE_CHUNK_OVERLAP=150

# Worker
API_BASE_URL=http://api:8000
WORKER_PUBLIC_URL=http://worker:8100
WORKER_SCOPE_REF_ID=workspace-main
WORKER_REPO_ROOT=/workspace
WORKER_SHELL=pwsh

# Browser Worker
BROWSER_WORKER_PUBLIC_URL=http://browser-worker:8200
BROWSER_WORKER_SCOPE_REF_ID=workspace-main
BROWSER_WORKER_HEADLESS=true
