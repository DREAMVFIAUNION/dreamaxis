    {
      "name": "Browser Open And Capture",
      "slug": "browser-open-capture",
      "description": "Open a URL, wait briefly, extract page text, and capture a screenshot.",
      "skill_mode": "browser",
      "required_runtime_type": "browser",
      "session_mode": "reuse",
      "command_template": "[{\"action\":\"open_url\",\"url\":\"{url}\"},{\"action\":\"wait_for\",\"time\":1},{\"action\":\"extract_text\"},{\"action\":\"take_screenshot\",\"name\":\"capture\"}]",
      "agent_role_slug": "builder",
      "tool_capabilities": [
        "open_url",
        "wait_for",
        "extract_text",
        "take_screenshot"
      ],
      "knowledge_scope": [
        "playwright-runtime"
      ],
      "input_schema": {
        "url": {
          "type": "string",
          "label": "Target URL"
        }
      },
      "required_capabilities": [
        "browser_runtime"
      ],
      "recommended_capabilities": [
        "playwright"
      ],
      "workspace_requirements": []
